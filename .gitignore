# 1. الاعتماديات والمكتبات (ضخمة جداً ويتم تحميلها عبر npm install)
node_modules/
jspm_packages/

# 2. ملفات المتغيرات البيئية والبيانات السرية (تحتوي على كلمات السر ومفاتيح الـ API)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 3. ملفات سجلات الأخطاء والتشغيل
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 4. مجلدات البناء والتوزيع (إذا كنت تستخدم TypeScript أو أدوات بناء)
dist/
build/
.next/
.nuxt/

# 5. ملفات النظام وبيئات التطوير الخاصة بالجهاز (مثل VS Code)
.vscode/
.idea/
.DS_Store
Thumbs.db

# 6. ملفات التغطية والاختبارات
coverage/
*.lcov
.nyc_output